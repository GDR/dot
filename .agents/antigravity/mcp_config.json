{
  "mcpServers": {
    "nixos": {
      "command": "nix",
      "args": [
        "run",
        "github:utensils/mcp-nixos",
        "--"
      ]
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${env.CONTEXT7_API_KEY}"
      }
    },
    "ghidra": {
      "command": "bridge-mcp-ghidra",
      "args": [],
      "env": {
        "GHIDRA_MCP_URL": "http://nix-oldstar:8089"
      }
    }
  }
}

